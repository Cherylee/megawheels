{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .brand-cta-carousel {
    width: 100%;
    max-width: none;
    padding: 0;
  }

  .brand-cta-carousel__track {
    display: flex;
    overflow: hidden;
    scroll-behavior: smooth;
    gap: {{ section.settings.gap }}px;
  }

  .brand-cta-carousel__item {
    flex: 0 0 100%;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .brand-cta-carousel__item:hover {
    transform: scale(1.02);
  }

  .brand-cta-carousel__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-cta-carousel__nav {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: {{ section.settings.gap }}px;
  }

  .brand-cta-carousel__dot {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_inactive_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
  }

  .brand-cta-carousel__dot.active {
    background-color: {{ section.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .brand-cta-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    background-color: rgba(0,0,0,0.5);
    color: {{ section.settings.arrow_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    z-index: 10;
  }

  .brand-cta-carousel__arrow:hover {
    background-color: rgba(0,0,0,0.8);
  }

  .brand-cta-carousel__arrow--prev {
    left: {{ section.settings.side_padding }}px;
  }

  .brand-cta-carousel__arrow--next {
    right: {{ section.settings.side_padding }}px;
  }

  .brand-cta-carousel__wrapper {
    position: relative;
  }

  @media screen and (max-width: 768px) {
    .brand-cta-carousel__track {
      gap: {{ section.settings.gap_mobile }}px;
    }

    .brand-cta-carousel__item {
      flex: 0 0 100%;
    }

    .brand-cta-carousel__arrow {
      display: none;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="brand-cta-carousel">
    <div class="brand-cta-carousel__wrapper">
      {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
        <button class="brand-cta-carousel__arrow brand-cta-carousel__arrow--prev" aria-label="Previous slide" onclick="carouselPrev('{{ section.id }}')">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="brand-cta-carousel__arrow brand-cta-carousel__arrow--next" aria-label="Next slide" onclick="carouselNext('{{ section.id }}')">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      {%- endif -%}

      <div class="brand-cta-carousel__track" id="carousel-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="brand-cta-carousel__item">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: '(max-width: 768px) 80vw, 400px', widths: '400,600,800,1000' -}}
              {%- else -%}
                {{- 'image' | placeholder_svg_tag: 'aspect-wide placeholder' -}}
              {%- endif -%}
            </a>
          {%- else -%}
            <div class="brand-cta-carousel__item">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: '(max-width: 768px) 80vw, 400px', widths: '400,600,800,1000' -}}
              {%- else -%}
                {{- 'image' | placeholder_svg_tag: 'aspect-wide placeholder' -}}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.show_dots and section.blocks.size > 1 -%}
      <div class="brand-cta-carousel__nav">
        {%- for block in section.blocks -%}
          <button class="brand-cta-carousel__dot" {% if forloop.first %}active{% endif %} onclick="goToSlide('{{ section.id }}', {{ forloop.index0 }})"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var sectionId = '{{ section.id }}';
    var track = document.getElementById('carousel-track-' + sectionId);
    var dots = document.querySelectorAll('#shopify-section-' + sectionId + ' .brand-cta-carousel__dot');
    var slideWidth = {{ section.settings.slide_width }};
    var gap = {{ section.settings.gap }};
    var autoPlay = {{ section.settings.auto_play | json }};
    var autoPlayInterval = {{ section.settings.auto_play_interval }};
    var currentIndex = 0;
    var totalSlides = dots.length;

    function updateSlidePosition() {
      var slideOffset = track.offsetWidth * currentIndex;
      track.scrollTo({
        left: slideOffset,
        behavior: 'smooth'
      });

      dots.forEach(function(dot, index) {
        if (index === currentIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }

    window.carouselNext = function(id) {
      if (id !== sectionId) return;
      currentIndex = (currentIndex + 1) % totalSlides;
      updateSlidePosition();
    };

    window.carouselPrev = function(id) {
      if (id !== sectionId) return;
      currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
      updateSlidePosition();
    };

    window.goToSlide = function(id, index) {
      if (id !== sectionId) return;
      currentIndex = index;
      updateSlidePosition();
    };

    if (autoPlay && totalSlides > 1) {
      setInterval(function() {
        currentIndex = (currentIndex + 1) % totalSlides;
        updateSlidePosition();
      }, autoPlayInterval * 1000);
    }
  });
</script>

{% schema %}
{
  "name": "Brand CTA Carousel",
  "class": "shopify-section--brand-cta-carousel",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 900,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Slide gap (desktop)",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Slide gap (mobile)",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "slide_width",
      "label": "Slide width (%)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "range",
      "id": "slide_width_mobile",
      "label": "Slide width mobile (%)",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "text",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "default": "16/9"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "auto_play",
      "label": "Auto play",
      "default": true
    },
    {
      "type": "range",
      "id": "auto_play_interval",
      "label": "Auto play interval (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.auto_play == true }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Arrow size",
      "min": 32,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Dot size",
      "min": 8,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Dot active color",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "dot_inactive_color",
      "label": "Dot inactive color",
      "default": "#444444"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "CTA Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "info": "Leave empty for no link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand CTA Carousel",
      "category": "Media",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}