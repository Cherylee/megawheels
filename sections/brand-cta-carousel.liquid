{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .brand-cta-carousel {
    width: 100%;
    max-width: none;
    padding: 0;
  }

  .brand-cta-carousel__track {
    display: flex;
    overflow: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    gap: {{ section.settings.gap }}px;
    border-radius: {{ section.settings.border_radius }}px;
  }

  .brand-cta-carousel__item {
    flex: 0 0 calc(100% - {{ section.settings.gap }}px);
    scroll-snap-align: start;
    margin-right: {{ section.settings.gap }}px;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }
  .brand-cta-carousel__item:last-child {
    margin-right: 0;
    flex: 0 0 100%;
  }

  .brand-cta-carousel__item:hover {
    {% comment %} transform: scale(1.02); {% endcomment %}
  }

  .brand-cta-carousel__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-cta-carousel__nav {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: {{ section.settings.gap }}px;
  }

  .brand-cta-carousel__dot {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_inactive_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
  }

  .brand-cta-carousel__dot.active {
    background-color: {{ section.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .brand-cta-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    background-color: rgba(0,0,0,0.5);
    color: {{ section.settings.arrow_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    z-index: 10;
    padding: 0;
    overflow: hidden;
  }

  .brand-cta-carousel__arrow img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .brand-cta-carousel__arrow:hover {
    background-color: rgba(0,0,0,0.8);
  }

  .brand-cta-carousel__arrow--prev {
    left: {{ section.settings.side_padding }}px;
  }

  .brand-cta-carousel__arrow--next {
    right: {{ section.settings.side_padding }}px;
  }

  .brand-cta-carousel__wrapper {
    position: relative;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }}{
      padding-top: {{ section.settings.mobile_padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom | default: 0 }}px;

      {%- if section.settings.mobile_show_arrows == false -%}
      .brand-cta-carousel__arrow {
        display: none;
      }
      {%- endif -%}

      .brand-cta-carousel__item {
        flex: 0 0 calc(100% - {{ section.settings.gap_mobile }}px);
        margin-right: {{ section.settings.gap_mobile }}px;
        aspect-ratio: auto;
        height: auto;
        overflow: visible;
        align-self: flex-start;
      }
      .brand-cta-carousel__item:last-child {
        margin-right: 0;
        flex: 0 0 100%;
      }
      .brand-cta-carousel__item picture,
      .brand-cta-carousel__item img {
        display: block;
        width: 100%;
        height: auto;
        object-fit: unset;
        max-width: 100%;
        border-radius: {{ section.settings.border_radius }}px;
      }
      .brand-cta-carousel__arrow{
        width: {{ section.settings.mobile_arrow_size }}px;
        height: {{ section.settings.mobile_arrow_size }}px;
        svg{
          width: {{ section.settings.mobile_arrow_svg_size }}px;
          height: {{ section.settings.mobile_arrow_svg_size }}px;
        }
      }
      .brand-cta-carousel__arrow--next{
        right: {{ section.settings.mobile_arrow_offset }}px;
      }
      .brand-cta-carousel__arrow--prev{
        left: {{ section.settings.mobile_arrow_offset }}px;
      }
      {%- if section.settings.mobile_show_nav -%}
        .brand-cta-carousel__nav {
          gap: {{ section.settings.mobile_nav_gap }}px;
        }
        .brand-cta-carousel__dot{
          width: {{ section.settings.mobile_dot_size }}px;
          height: {{ section.settings.mobile_dot_size }}px;
        }
      {%- else -%}
        .brand-cta-carousel__nav {
          display: none;
        }
      {%- endif -%}
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="brand-cta-carousel">
    <div class="brand-cta-carousel__wrapper">
      {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
        {%- comment -%} 上一页按钮：优先使用上传图片，回退到默认 SVG {%- endcomment -%}
        <button class="brand-cta-carousel__arrow brand-cta-carousel__arrow--prev" aria-label="Previous slide" onclick="carouselPrev('{{ section.id }}')">
          {%- if section.settings.arrow_prev_image != blank -%}
            {{- section.settings.arrow_prev_image | image_url: width: 40 | image_tag: loading: 'lazy', alt: 'Previous' -}}
          {%- else -%}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          {%- endif -%}
        </button>
        {%- comment -%} 下一页按钮：优先使用上传图片，回退到默认 SVG {%- endcomment -%}
        <button class="brand-cta-carousel__arrow brand-cta-carousel__arrow--next" aria-label="Next slide" onclick="carouselNext('{{ section.id }}')">
          {%- if section.settings.arrow_next_image != blank -%}
            {{- section.settings.arrow_next_image | image_url: width: 40 | image_tag: loading: 'lazy', alt: 'Next' -}}
          {%- else -%}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          {%- endif -%}
        </button>
      {%- endif -%}

      <div class="brand-cta-carousel__track" id="carousel-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="brand-cta-carousel__item">
              {%- if block.settings.image != blank -%}
                <picture>
                  {%- if block.settings.mobile_image != blank -%}
                    <source media="(max-width: 699px)" srcset="{{ block.settings.mobile_image | image_url: width: 800 }} 800w" sizes="100vw">
                    {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: '100vw', widths: '400,600,800,1000,1200,1600,2000,2400' -}}
                  {%- else -%}
                    {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: '100vw', widths: '400,600,800,1000,1200,1600,2000,2400' -}}
                  {%- endif -%}
                </picture>
              {%- else -%}
                {{- 'image' | placeholder_svg_tag: 'aspect-wide placeholder' -}}
              {%- endif -%}
            </a>
          {%- else -%}
            <div class="brand-cta-carousel__item">
              {%- if block.settings.image != blank -%}
                <picture>
                  {%- if block.settings.mobile_image != blank -%}
                    <source media="(max-width: 699px)" srcset="{{ block.settings.mobile_image | image_url: width: 800 }} 800w" sizes="100vw">
                    {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: '100vw', widths: '400,600,800,1000,1200,1600,2000,2400' -}}
                  {%- else -%}
                    {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: sizes: '100vw', widths: '400,600,800,1000,1200,1600,2000,2400' -}}
                  {%- endif -%}
                </picture>
              {%- else -%}
                {{- 'image' | placeholder_svg_tag: 'aspect-wide placeholder' -}}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.show_dots and section.blocks.size > 1 -%}
      <div class="brand-cta-carousel__nav">
        {%- for block in section.blocks -%}
          <button class="brand-cta-carousel__dot" {% if forloop.first %}active{% endif %} onclick="goToSlide('{{ section.id }}', {{ forloop.index0 }})"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var sectionId = '{{ section.id }}';
    var track = document.getElementById('carousel-track-' + sectionId);
    var dots = document.querySelectorAll('#shopify-section-' + sectionId + ' .brand-cta-carousel__dot');
    var slideWidth = {{ section.settings.slide_width }};
    var gap = {{ section.settings.gap }};
    var autoPlay = {{ section.settings.auto_play | json }};
    var autoPlayInterval = {{ section.settings.auto_play_interval }};
    var currentIndex = 0;
    var totalSlides = dots.length;

    function updateSlidePosition() {
      var slideOffset = track.offsetWidth * currentIndex;
      track.scrollTo({
        left: slideOffset,
        behavior: 'smooth'
      });

      dots.forEach(function(dot, index) {
        if (index === currentIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }

    window.carouselNext = function(id) {
      if (id !== sectionId) return;
      currentIndex = (currentIndex + 1) % totalSlides;
      updateSlidePosition();
    };

    window.carouselPrev = function(id) {
      if (id !== sectionId) return;
      currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
      updateSlidePosition();
    };

    window.goToSlide = function(id, index) {
      if (id !== sectionId) return;
      currentIndex = index;
      updateSlidePosition();
    };

    if (autoPlay && totalSlides > 1) {
      setInterval(function() {
        currentIndex = (currentIndex + 1) % totalSlides;
        updateSlidePosition();
      }, autoPlayInterval * 1000);
    }
  });
</script>

{% schema %}
{
