{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    background: linear-gradient(180deg,#000000,#005fd1);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  .dual-column-feature {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  .dual-column-feature__card {
    background-color: {{ section.settings.card_background }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.column_gap }}px;
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    justify-content: center;
  }

  .dual-column-feature__column {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .dual-column-feature__image {
    width: 100%;
    height: {{ section.settings.image_height }}px;
    object-fit: cover;
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  .dual-column-feature__title {
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: bold;
    color: {{ section.settings.title_color }};
    margin: 0;
  }

  .dual-column-feature__description {
    font-size: {{ section.settings.description_font_size }}px;
    color: {{ section.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .dual-column-feature__separator {
    border-left: {{ section.settings.separator_width }}px dashed {{ section.settings.separator_color }};
  }
  .aspect-square1{
    aspect-ratio: 6 / 1;
  }

  @media screen and (max-width: 768px) {
    .dual-column-feature__card {
      grid-template-columns: 1fr;
      gap: {{ section.settings.column_gap_mobile }}px;
    }

    .dual-column-feature__separator {
      border-left: none;
      border-top: {{ section.settings.separator_width }}px dashed {{ section.settings.separator_color }};
    }

    .dual-column-feature__image {
      height: {{ section.settings.image_height_mobile }}px;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="dual-column-feature">
    <div class="dual-column-feature__card">
      <div class="dual-column-feature__column">
        {%- if section.settings.left_image != blank -%}
          {{ section.settings.left_image | image_url: width: 800 | image_tag: class: 'dual-column-feature__image', alt: section.settings.left_image.alt }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'aspect-square1 placeholder' }}
        {%- endif -%}
        <p class="dual-column-feature__description">{{ section.settings.left_description }}</p>
      </div>

      <div class="dual-column-feature__separator"></div>

      <div class="dual-column-feature__column">
        {%- if section.settings.right_image != blank -%}
          {{ section.settings.right_image | image_url: width: 800 | image_tag: class: 'dual-column-feature__image', alt: section.settings.right_image.alt }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'aspect-square1 placeholder' }}
        {%- endif -%}
        <p class="dual-column-feature__description">{{ section.settings.right_description }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Dual Column Feature",
  "class": "shopify-section--dual-column-feature",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"]
  },
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 900,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "Column gap (mobile)",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height (desktop)",
      "min": 100,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "Image height (mobile)",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "separator_width",
      "label": "Separator width",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#cccccc"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left column image"
    },
    {
      "type": "textarea",
      "id": "left_description",
      "label": "Left column description",
      "default": "Use this text to share information about your brand with your customers."
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right column image"
    },
    {
      "type": "textarea",
      "id": "right_description",
      "label": "Right column description",
      "default": "Use this text to share information about your brand with your customers."
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 14,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Dual Column Feature",
      "category": "Text"
    }
  ]
}
{% endschema %}