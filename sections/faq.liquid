{%- render 'section-spacing-collapsing' -%}

{%- assign text_position = section.settings.text_position -%}

<style>
  {%- comment -%} Section 背景渐变：颜色1/2/3 全部设置才启用自定义渐变 {%- endcomment -%}
  {%- liquid
    assign sec_c1 = section.settings.section_gradient_color_1
    assign sec_c2 = section.settings.section_gradient_color_2
    assign sec_c3 = section.settings.section_gradient_color_3
    assign sec_angle = section.settings.section_gradient_angle | default: '0'
    assign sec_pos1 = section.settings.section_gradient_position_1 | default: '-1'
    assign sec_pos2 = section.settings.section_gradient_position_2 | default: '5'
    assign sec_pos3 = section.settings.section_gradient_position_3 | default: '80'
  -%}
  {%- assign sec_gradient_custom = false -%}
  {%- if sec_c1 != blank and sec_c2 != blank and sec_c3 != blank -%}
    {%- assign sec_gradient_custom = true -%}
  {%- endif -%}

  {%- liquid
    assign wrap_c1 = section.settings.wrapper_gradient_color_1
    assign wrap_c2 = section.settings.wrapper_gradient_color_2
    assign wrap_c3 = section.settings.wrapper_gradient_color_3
    assign wrap_angle = section.settings.wrapper_gradient_angle | default: '0'
    assign wrap_pos1 = section.settings.wrapper_gradient_position_1 | default: '0'
    assign wrap_pos2 = section.settings.wrapper_gradient_position_2 | default: '10'
    assign wrap_pos3 = section.settings.wrapper_gradient_position_3 | default: '80'
  -%}
  {%- assign wrap_gradient_custom = false -%}
  {%- if wrap_c1 != blank and wrap_c2 != blank and wrap_c3 != blank -%}
    {%- assign wrap_gradient_custom = true -%}
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --section-stack-intro: {% if text_position == 'center' %}60%{% else %}50%{% endif %};
    --section-stack-main: {% if text_position == 'center' %}60%{% else %}50%{% endif %};
    {%- if sec_gradient_custom -%}
      background: linear-gradient({{ sec_angle }}deg, {{ sec_c1 }} {{ sec_pos1 }}%, {{ sec_c2 }} {{ sec_pos2 }}%, {{ sec_c3 }} {{ sec_pos3 }}%);
    {%- elsif section.settings.section_background != blank -%}
      background: {{ section.settings.section_background }};
    {%- else -%}
      background: linear-gradient(0deg, #5a0909 -1%, #200505 5%, #000000 80%);
    {%- endif -%}
  }

  .section-stack__main2 {
    width: 100%;
    max-width: {{ section.settings.wrapper_max_width }}px;
    margin-top: {{ section.settings.wrapper_margin_top }}px;
    margin-bottom: {{ section.settings.wrapper_margin_bottom }}px;
    margin-left: auto;
    margin-right: auto;
    box-shadow: 0 90px 800px 10px rgba(255, 255, 255, 0.1);
    {%- comment -%} 背景：自定义渐变 > 纯色 > 默认 {%- endcomment -%}
    {%- if wrap_gradient_custom -%}
      background: linear-gradient({{ wrap_angle }}deg, {{ wrap_c1 }} {{ wrap_pos1 }}%, {{ wrap_c2 }} {{ wrap_pos2 }}%, {{ wrap_c3 }} {{ wrap_pos3 }}%);
      padding: {{ section.settings.wrapper_padding_vertical }}px {{ section.settings.wrapper_padding_horizontal }}px;
      border-radius: {{ section.settings.wrapper_border_radius }}px;
    {%- elsif section.settings.wrapper_background != blank -%}
      background: {{ section.settings.wrapper_background }};
      padding: {{ section.settings.wrapper_padding_vertical }}px {{ section.settings.wrapper_padding_horizontal }}px;
      border-radius: {{ section.settings.wrapper_border_radius }}px;
    {%- else -%}
      background: linear-gradient(0deg, #271716 0%, #1f1817 10%, #151414 80%);
      padding: 28px 0px;
      border-radius: 20px;
    {%- endif -%}
  }

  .section-stack__main1 {
    width: 100%;
    max-width: 1440px;
  }
  .section-stack__intro1 {
    width: 100%;
    max-width: 1440px;
    padding: 0px 24px;
    text-align: {{ section.settings.intro_alignment }};
  }
  {%- comment -%} 标题 h2 字体大小 & 颜色 {%- endcomment -%}
  #shopify-section-{{ section.id }} .section-stack__intro1 .h2 {
    font-size: {{ section.settings.intro_heading_font_size }}px;
    color: {{ section.settings.intro_heading_color }};
    margin-bottom: 16px;
  }
  {%- comment -%} 副标题 / 文案字体大小 & 颜色 {%- endcomment -%}
  #shopify-section-{{ section.id }} .section-stack__intro1 .subheading,
  #shopify-section-{{ section.id }} .section-stack__intro1 .prose {
    font-size: {{ section.settings.intro_text_font_size }}px;
    color: {{ section.settings.intro_text_color }};
  }

  .section-stack__main1_content {
    background: none;
    padding: 0px 24px;
  }

  {%- comment -%} 自定义下拉图标：隐藏默认 chevron，用上传图片替代 {%- endcomment -%}
  {%- if section.settings.toggle_icon != blank -%}
    #shopify-section-{{ section.id }} .accordion .circle-chevron svg {
      display: none;
    }
    #shopify-section-{{ section.id }} .accordion .circle-chevron {
      background-image: url({{ section.settings.toggle_icon | image_url: width: 48 }});
      background-size: 60%;
      background-repeat: no-repeat;
      background-position: center;
    }
    #shopify-section-{{ section.id }} .accordion[open] .circle-chevron {
      background-image: url({{ section.settings.toggle_icon_open | default: section.settings.toggle_icon | image_url: width: 48 }});
    }
  {%- endif -%}

  {%- comment -%} 问题下划线粗细：0=细线, 1-6=逐级加粗 {%- endcomment -%}
  #shopify-section-{{ section.id }} .accordion-box .accordion {
    border-block-end-width: {% if section.settings.border_width == 0 %}0.5{% else %}{{ section.settings.border_width }}{% endif %}px;
    border-color: {{ section.settings.border_color }};
  }

  {%- comment -%} wrapper 配置了自定义背景时，覆盖默认值 {%- endcomment -%}
  {%- if section.settings.wrapper_background != blank or wrap_gradient_custom -%}
    #shopify-section-{{ section.id }} .section-stack__main2 {
      padding: {{ section.settings.wrapper_padding_vertical }}px {{ section.settings.wrapper_padding_horizontal }}px;
      border-radius: {{ section.settings.wrapper_border_radius }}px;
      {%- if wrap_gradient_custom -%}
        background: linear-gradient({{ wrap_angle }}deg, {{ wrap_c1 }} {{ wrap_pos1 }}%, {{ wrap_c2 }} {{ wrap_pos2 }}%, {{ wrap_c3 }} {{ wrap_pos3 }}%);
      {%- else -%}
        background: {{ section.settings.wrapper_background }};
      {%- endif -%}
    }
  {%- endif -%}
</style>

<div >
  <div class="section-stack section-stack__main2 {% if text_position != 'center' %}section-stack--horizontal{% else %}section-stack--center{% endif %} {% if text_position == 'end' %}section-stack--reverse{% endif %}">
    {%- capture content -%}
      {%- if section.settings.subheading != blank -%}
        <p class="subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="h2">
          {%- render 'styled-text', content: section.settings.title, text_color: section.settings.heading_color, gradient: section.settings.heading_gradient -%}
        </h2>
      {%- endif -%}

      {{- section.settings.content -}}
    {%- endcapture -%}

    {%- capture subcontent -%}
      <div class="faq-availability">
        {%- if section.settings.team_avatar != blank or section.settings.support_hours != blank or section.settings.answer_time != blank -%}
          <div class="v-stack gap-4">
            {%- if section.settings.team_avatar != blank -%}
              {%- capture sizes -%}{{ section.settings.team_avatar_width }}px{%- endcapture -%}
              {%- capture widths -%}{{ section.settings.team_avatar_width }}, {{ section.settings.team_avatar_width | times: 2 | at_most: section.settings.team_avatar.width }}{%- endcapture -%}
              {%- capture style -%}max-width: {{ section.settings.team_avatar_width }}px{%- endcapture -%}
              {{- section.settings.team_avatar | image_url: width: section.settings.team_avatar.width | image_tag: style: style, sizes: sizes, widths: widths -}}
            {%- endif -%}

            {%- if section.settings.support_hours != blank or section.settings.answer_time != blank -%}
              <div class="v-stack">
                {{- section.settings.support_hours -}}

                {%- if section.settings.answer_time != blank -%}
                  <span class="text-subdued">{{ section.settings.answer_time }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          {% render 'button', content: section.settings.button_text, href: section.settings.button_url, size: 'xl', background: section.settings.button_background, text_color: section.settings.button_text_color %}
        {%- endif -%}
      </div>
    {%- endcapture -%}

    {%- if content != blank or subcontent != blank -%}
      <div class="section-stack__intro section-stack__intro1" >
        <div class="v-stack gap-10">
          {%- if content != blank -%}
            <div class="prose">
              {{- content -}}
            </div>
          {%- endif -%}

          {%- if text_position != 'center' and subcontent != blank -%}
            <div class="hidden lg:block">
              {{- subcontent -}}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="section-stack__main section-stack__main1" >
        <div {% render 'surface', class: 'accordion-box rounded section-stack__main1_content', background: section.settings.accordion_background, text_color: section.settings.accordion_text_color, background_fallback: 'bg-secondary' %}>
          {%- for block in section.blocks -%}
            {%- if block.settings.title != blank and block.settings.content != blank -%}
              {%- capture accordion_content -%}
                <div class="prose">{{ block.settings.content }}</div>
              {%- endcapture -%}

              {%- render 'accordion', title: block.settings.title, content: accordion_content, block: block -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div {% if text_position != 'center' %}class="lg:hidden"{% endif %}>
      {{- subcontent -}}
    </div>
  </div>
</div>

{%- comment -%}On the FAQ page, we also output the content with JSON microdata for SEO{%- endcomment -%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in section.blocks -%}
        {
          "@type": "Question",
          "name": {{ block.settings.title | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.content | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>

{% schema %}
