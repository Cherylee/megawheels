{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .product-reviews-grid {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  .product-reviews-grid__title {
    text-align: {{ section.settings.title_alignment }};
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_font_size }};
    font-weight: 700;
    margin-bottom: {{ section.settings.title_margin_bottom }}px;
  }

  .product-reviews-grid__items {
    display: flex;
    align-items: flex-start;
    gap: {{ section.settings.gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .product-reviews-grid__items::-webkit-scrollbar {
    display: none;
  }

  /* 固定整张卡片总高度，所有卡片等高 */
  .product-reviews-grid__item {
    flex: 0 0 calc((100% - {{ section.settings.columns | minus: 1 | times: section.settings.gap }}px) / {{ section.settings.columns }});
    background-color: {{ section.settings.card_background | default: '#ffffff' }};
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: {{ section.settings.card_total_height }}px;
  }

  .product-reviews-grid__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.3);
  }

  /* 图片自适应高度，不强制固定比例 */
  .product-reviews-grid__image {
    overflow: hidden;
    flex-shrink: 0;
  }

  .product-reviews-grid__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* 文字容器占满卡片剩余全部高度，图片越小文字区域越高 */
  .product-reviews-grid__content {
    padding: {{ section.settings.card_padding }}px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .product-reviews-grid__product-link {
    text-decoration: none;
    color: inherit;
  }

  .product-reviews-grid__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
    flex-shrink: 0;
  }

  .product-reviews-grid__stars {
    display: flex;
    gap: 2px;
  }

  .product-reviews-grid__star {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    fill: {{ section.settings.star_color }};
  }

  /* 核心修复：固定最大渲染行数，超出自动省略，容器自适应留白 */
  .product-reviews-grid__review-text {
    color: {{ section.settings.review_text_color | default: '#333333' }};
    font-size: {{ section.settings.review_text_font_size }}px;
    line-height: 1.5;
    margin-bottom: 4px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: {{ section.settings.review_text_max_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    /* 取消固定高度，依靠flex容器自动留白 */
    height: auto;
  }

  .product-reviews-grid__reviewer {
    color: {{ section.settings.reviewer_color | default: '#333333' }};
    font-size: {{ section.settings.reviewer_font_size }}px;
    font-weight: 700;
    margin-bottom: 6px;
    flex-shrink: 0;
  }

  .product-reviews-grid__scroller {
    position: relative;
  }

  .product-reviews-grid__scroll-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(0,0,0,0.6);
    color: #fff;
    border: none;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease, background-color 0.3s ease;
  }
  .product-reviews-grid__scroll-arrow:hover {
    background-color: rgba(0,0,0,0.85);
  }
  .product-reviews-grid__scroll-arrow--visible {
    display: flex;
  }
  .product-reviews-grid__scroll-arrow--prev {
    left: 0;
  }
  .product-reviews-grid__scroll-arrow--next {
    right: 0;
  }

  @media screen and (max-width: 1024px) {
    .product-reviews-grid__item {
      flex: 0 0 calc((100% - {{ section.settings.columns_tablet | minus: 1 | times: section.settings.gap }}px) / {{ section.settings.columns_tablet }});
      height: {{ section.settings.card_total_height_tablet }}px;
    }
  }

  @media screen and (max-width: 768px) {
    .product-reviews-grid__item {
      flex: 0 0 calc((100% - {{ section.settings.columns_mobile | minus: 1 | times: section.settings.gap_mobile }}px) / {{ section.settings.columns_mobile }});
      height: {{ section.settings.card_total_height_mobile }}px;
    }
    .product-reviews-grid__items {
      gap: {{ section.settings.gap_mobile }}px;
    }
    .product-reviews-grid{
      padding:0;
    }
    #shopify-section-{{ section.id }}{
      padding-top: {{ section.settings.mobile_padding_top | default: 0 }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom | default: 0 }}px;
      .product-reviews-grid__scroll-arrow{
        width: {{ section.settings.mobile_arrow_size }}px;
        height: {{ section.settings.mobile_arrow_size }}px;
      } 
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="product-reviews-grid">
    {%- if section.settings.title != blank -%}
      <h2 class="product-reviews-grid__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="product-reviews-grid__scroller">
      <div class="product-reviews-grid__items" id="reviews-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- assign product = all_products[block.settings.product_handle] -%}
          {%- if product -%}
            {%- assign star_count = block.settings.star_rating | default: 5 -%}
            {%- assign empty_stars = 5 | minus: star_count -%}
            {%- assign display_image = block.settings.image | default: product.featured_image -%}

            <div class="product-reviews-grid__item">
              <a href="{{ product.url }}" class="product-reviews-grid__product-link">
                <div class="product-reviews-grid__image">
                  {{- display_image | image_url: width: display_image.width | image_tag: sizes: '(max-width: 480px) 50vw, (max-width: 768px) 33vw, 300px', widths: '300,400,600,800,1000,1200', alt: product.title | escape -}}
                </div>
              </a>
              
              <div class="product-reviews-grid__content">
                {%- if block.settings.reviewer_name != blank -%}
                  <p class="product-reviews-grid__reviewer">@{{ block.settings.reviewer_name | escape }}</p>
                {%- endif -%}
                <div class="product-reviews-grid__rating">
                  <div class="product-reviews-grid__stars">
                    {%- for i in (1..star_count) -%}
                      <svg class="product-reviews-grid__star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {%- endfor -%}
                    {%- for i in (1..empty_stars) -%}
                      <svg class="product-reviews-grid__star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="fill: #ddd;">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                </div>
  
                {%- if block.settings.review_text != blank -%}
                  <a href="{{ product.url }}" class="product-reviews-grid__product-link">
                    <p class="product-reviews-grid__review-text">{{ block.settings.review_text | escape }}</p>
                  </a>
                {%- else -%}
                  <p class="product-reviews-grid__review-text"></p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <button class="product-reviews-grid__scroll-arrow product-reviews-grid__scroll-arrow--prev" id="reviews-arrow-prev-{{ section.id }}" aria-label="Scroll left" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      <button class="product-reviews-grid__scroll-arrow product-reviews-grid__scroll-arrow--next" id="reviews-arrow-next-{{ section.id }}" aria-label="Scroll right" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var track = document.getElementById('reviews-track-' + sectionId);
    var arrowPrev = document.getElementById('reviews-arrow-prev-' + sectionId);
    var arrowNext = document.getElementById('reviews-arrow-next-' + sectionId);
    if (!track || !arrowPrev || !arrowNext) return;

    var autoPlay = {{ section.settings.auto_play | default: true | json }};
    var autoPlayInterval = {{ section.settings.auto_play_interval | default: 3000 }};
    var autoPlayTimer = null;

    function getScrollAmount() {
      return track.querySelector('.product-reviews-grid__item').offsetWidth + {{ section.settings.gap }};
    }

    function checkOverflow() {
      var overflowRight = track.scrollWidth > track.clientWidth + 2;
      var scrollLeft = track.scrollLeft;
      var maxScroll = track.scrollWidth - track.clientWidth;

      if (overflowRight && scrollLeft > 10) {
        arrowPrev.classList.add('product-reviews-grid__scroll-arrow--visible');
      } else {
        arrowPrev.classList.remove('product-reviews-grid__scroll-arrow--visible');
      }

      if (overflowRight && scrollLeft < maxScroll - 10) {
        arrowNext.classList.add('product-reviews-grid__scroll-arrow--visible');
      } else {
        arrowNext.classList.remove('product-reviews-grid__scroll-arrow--visible');
      }
    }

    function scrollNext() {
      var maxScroll = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= maxScroll - 5) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      }
    }

    function startAutoPlay() {
      if (!autoPlay) return;
      stopAutoPlay();
      autoPlayTimer = setInterval(scrollNext, autoPlayInterval);
    }

    function stopAutoPlay() {
      if (autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
      }
    }

    arrowPrev.addEventListener('click', function() {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      stopAutoPlay();
      startAutoPlay();
    });

    arrowNext.addEventListener('click', function() {
      scrollNext();
      stopAutoPlay();
      startAutoPlay();
    });

    track.addEventListener('scroll', checkOverflow);
    track.addEventListener('touchstart', stopAutoPlay);
    track.addEventListener('touchend', function() {
      setTimeout(startAutoPlay, 500);
    });

    checkOverflow();
    window.addEventListener('resize', checkOverflow);
    startAutoPlay();
  })();
</script>

