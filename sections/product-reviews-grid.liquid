{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .product-reviews-grid {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.side_padding }}px;
  }

  .product-reviews-grid__title {
    text-align: {{ section.settings.title_alignment }};
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: 700;
    margin-bottom: {{ section.settings.title_margin_bottom }}px;
  }

  .product-reviews-grid__items {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  .product-reviews-grid__item {
    background-color: {{ section.settings.card_background }};
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-reviews-grid__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.3);
  }

  .product-reviews-grid__image {
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .product-reviews-grid__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-reviews-grid__content {
    padding: {{ section.settings.card_padding }}px;
  }

  .product-reviews-grid__product-link {
    text-decoration: none;
    color: inherit;
  }

  .product-reviews-grid__product-title {
    color: {{ section.settings.product_title_color }};
    font-size: {{ section.settings.product_title_font_size }}px;
    font-weight: 600;
    margin-bottom: 8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-reviews-grid__rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }

  .product-reviews-grid__stars {
    display: flex;
    gap: 2px;
  }

  .product-reviews-grid__star {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    fill: {{ section.settings.star_color }};
  }

  .product-reviews-grid__review-count {
    color: {{ section.settings.review_count_color }};
    font-size: {{ section.settings.review_count_font_size }}px;
  }

  .product-reviews-grid__review-text {
    color: {{ section.settings.review_text_color }};
    font-size: {{ section.settings.review_text_font_size }}px;
    line-height: 1.5;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: {{ section.settings.review_text_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-reviews-grid__reviewer {
    color: {{ section.settings.reviewer_color }};
    font-size: {{ section.settings.reviewer_font_size }}px;
    font-style: italic;
  }

  .product-reviews-grid__price {
    color: {{ section.settings.price_color }};
    font-size: {{ section.settings.price_font_size }}px;
    font-weight: 600;
    margin-top: 8px;
  }

  @media screen and (max-width: 1024px) {
    .product-reviews-grid__items {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .product-reviews-grid__items {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.gap_mobile }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .product-reviews-grid__items {
      grid-template-columns: 1fr;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="product-reviews-grid">
    {%- if section.settings.title != blank -%}
      <h2 class="product-reviews-grid__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="product-reviews-grid__items">
      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product_handle] -%}
        {%- if product -%}
          {%- assign review_rating = product.metafields['app--4551725'].ratings.value.ratings | plus: 0 -%}
          {%- assign review_count = product.metafields['app--4551725'].ratings.value.raters | plus: 0 -%}
          {%- assign star_count = review_rating | floor -%}
          {%- assign empty_stars = 5 | minus: star_count -%}

          <div class="product-reviews-grid__item">
            <a href="{{ product.url }}" class="product-reviews-grid__product-link">
              <div class="product-reviews-grid__image">
                {{- product.featured_image | image_url: width: 400 | image_tag: sizes: '(max-width: 480px) 100%, (max-width: 768px) 50vw, 300px' -}}
              </div>
            </a>

            <div class="product-reviews-grid__content">
              <a href="{{ product.url }}" class="product-reviews-grid__product-link">
                <div class="product-reviews-grid__product-title">{{ product.title }}</div>
              </a>

              <div class="product-reviews-grid__rating">
                <div class="product-reviews-grid__stars">
                  {%- for i in (1..star_count) -%}
                    <svg class="product-reviews-grid__star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {%- endfor -%}
                  {%- for i in (1..empty_stars) -%}
                    <svg class="product-reviews-grid__star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="fill: #ddd;">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {%- endfor -%}
                </div>
                {%- if review_count > 0 -%}
                  <span class="product-reviews-grid__review-count">({{ review_count }})</span>
                {%- endif -%}
              </div>

              {%- if block.settings.review_text != blank -%}
                <p class="product-reviews-grid__review-text">{{ block.settings.review_text | escape }}</p>
                {%- if block.settings.reviewer_name != blank -%}
                  <p class="product-reviews-grid__reviewer">— {{ block.settings.reviewer_name | escape }}</p>
                {%- endif -%}
              {%- endif -%}

              <div class="product-reviews-grid__price">{{ product.price | money }}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

