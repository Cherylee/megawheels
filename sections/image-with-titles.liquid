      "id": "mobile_title_spacing",
      "label": "Mobile space between title and subtitle",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile top padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_left",
      "label": "Mobile left padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_right",
      "label": "Mobile right padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image with titles"
    }
  ]
