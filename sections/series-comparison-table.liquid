{%- render 'section-spacing-collapsing' -%}

{%- assign product_1 = all_products[section.settings.product_1_handle] -%}
{%- assign product_2 = all_products[section.settings.product_2_handle] -%}
{%- assign product_3 = all_products[section.settings.product_3_handle] -%}

{%- assign product_1_image = section.settings.product_1_image | default: product_1.featured_image -%}
{%- assign product_2_image = section.settings.product_2_image | default: product_2.featured_image -%}
{%- assign product_3_image = section.settings.product_3_image | default: product_3.featured_image -%}

{%- assign product_1_title = section.settings.product_1_title | default: product_1.title -%}
{%- assign product_2_title = section.settings.product_2_title | default: product_2.title -%}
{%- assign product_3_title = section.settings.product_3_title | default: product_3.title -%}

{%- comment -%} 折扣价计算：支持百分比(%)或固定金额 {%- endcomment -%}
{%- assign discount_1 = section.settings.product_1_discount_price | strip -%}
{%- assign discount_2 = section.settings.product_2_discount_price | strip -%}
{%- assign discount_3 = section.settings.product_3_discount_price | strip -%}

{%- comment -%} Product 1: 折扣价 & 原价 {%- endcomment -%}
{%- assign p1_display_price = product_1.price -%}
{%- assign p1_compare_price = product_1.compare_at_price -%}
{%- if discount_1 != blank and product_1 -%}
  {%- if discount_1 contains '%' -%}
    {%- assign pct = discount_1 | remove: '%' | times: 1 -%}
    {%- assign discount_amount = product_1.price | times: pct | divided_by: 100 -%}
    {%- assign p1_display_price = product_1.price | minus: discount_amount -%}
  {%- else -%}
    {%- assign p1_display_price = discount_1 | times: 100 -%}
  {%- endif -%}
  {%- assign p1_compare_price = product_1.price -%}
{%- endif -%}

{%- comment -%} Product 2 {%- endcomment -%}
{%- assign p2_display_price = product_2.price -%}
{%- assign p2_compare_price = product_2.compare_at_price -%}
{%- if discount_2 != blank and product_2 -%}
  {%- if discount_2 contains '%' -%}
    {%- assign pct = discount_2 | remove: '%' | times: 1 -%}
    {%- assign discount_amount = product_2.price | times: pct | divided_by: 100 -%}
    {%- assign p2_display_price = product_2.price | minus: discount_amount -%}
  {%- else -%}
    {%- assign p2_display_price = discount_2 | times: 100 -%}
  {%- endif -%}
  {%- assign p2_compare_price = product_2.price -%}
{%- endif -%}

{%- comment -%} Product 3 {%- endcomment -%}
{%- assign p3_display_price = product_3.price -%}
{%- assign p3_compare_price = product_3.compare_at_price -%}
{%- if discount_3 != blank and product_3 -%}
  {%- if discount_3 contains '%' -%}
    {%- assign pct = discount_3 | remove: '%' | times: 1 -%}
    {%- assign discount_amount = product_3.price | times: pct | divided_by: 100 -%}
    {%- assign p3_display_price = product_3.price | minus: discount_amount -%}
  {%- else -%}
    {%- assign p3_display_price = discount_3 | times: 100 -%}
  {%- endif -%}
  {%- assign p3_compare_price = product_3.price -%}
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} {
    padding-top: 20px;
    padding-bottom: 20px;
    background: linear-gradient(0deg, #5a0909 -1%, #200505 5%, #000000 80%);
  }
  .series-comparison-table-sl{
    position: relative;
  }
  

  .series-comparison-table {
    max-width: 1240px;
    margin: 0 auto;
    {% comment %} background: rgba(21,20,20,0.5); {% endcomment %}
    border-radius: 30px;
    overflow: hidden;
    padding: 20px 20px;
    box-shadow: 0 90px 800px 10px rgba(255, 255, 255, 0.1);
    background: linear-gradient(0deg, #271716 0%, #1f1817 10%, #151414 80%);
   }

  .series-comparison-table__header {
    display: grid;
    grid-template-columns: 1fr repeat(3, 1fr);
    gap: {{ section.settings.column_gap }}px;
    margin-bottom: {{ section.settings.header_body_gap }}px;
    padding-bottom: {{ section.settings.header_body_gap }}px;
  }
  
  .series-comparison-table__header-cell {
    text-align: center;
  }

  .series-comparison-table__product-image {
    aspect-ratio: {{ section.settings.product_image_aspect_ratio }};
    overflow: hidden;
    margin-bottom: {{ section.settings.image_title_gap }}px;
    {%- comment -%} 产品图最大宽度限制，防止撑开列宽 {%- endcomment -%}
    max-width: {{ section.settings.product_image_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .series-comparison-table__product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: transparent;
  }

  .series-comparison-table__product-title-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: {{ section.settings.title_price_gap }}px;
    width: {{ section.settings.title_bg_width }}px;
    height: {{ section.settings.title_bg_height }}px;
  }

  .series-comparison-table__product-title-bg {
    position: absolute;
    width: 100%;
    height: 100%;
    background: url('https://cdn.shopify.com/s/files/1/0593/5883/8992/files/huaban-5539078913.png?v=1783930065') no-repeat center center;
    z-index: 0;
    background-size: 100% 100%;
  }

  .series-comparison-table__product-title {
    position: relative;
    color: {{ section.settings.product_title_color }};
    font-size: {{ section.settings.product_title_font_size }}px;
    font-weight: 800;
    text-decoration: none;
    display: inline-block;
    z-index: 1;
    padding: 4px 16px;
    width: 100%;
    left: {{ section.settings.title_offset_x }}px;
  }

  .series-comparison-table__product-price {
    font-weight: 800;
    background: linear-gradient(0deg, #f10606 40%, #ffffff 100%)!important;
    -webkit-background-clip: text!important;
    background-clip: text!important;
    color: transparent;
    font-size: {{ section.settings.price_font_size }}px;
    display: inline-block;
  }

  .series-comparison-table__product-compare-at-price {
    font-size: {{ section.settings.compare_at_font_size }}px;
    color: {{ section.settings.compare_at_color }};
    text-decoration: line-through;
    display: inline-block;
    vertical-align: middle;
  }

  .series-comparison-table__product-price-wrap {
    margin-bottom: {{ section.settings.price_button_gap }}px;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .series-comparison-table__product-button {
    display: inline-block;
    padding: 4px 16px;
    background: linear-gradient(180deg, {{ section.settings.button_background }} 0%, {{ section.settings.button_background_dark }} 100%);
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .series-comparison-table__product-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(255,0,0,0.4);
  }

  .series-comparison-table__body {
    display: grid;
    grid-template-columns: 1fr repeat(3, 1fr);
    gap: {{ section.settings.column_gap }}px {{ section.settings.row_gap }}px;
  }

  .series-comparison-table__row {
    display: contents;
  }

  .series-comparison-table__label>p{
    font-size: {{ section.settings.label_font_size }}px;
    font-weight: 800;
    padding: 10px;
    align-self: center;
    text-align: left;
    background: linear-gradient(45deg, #f10606 20%, #ffc5c5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .series-comparison-table__value {
    color: {{ section.settings.value_color }};
    font-size: {{ section.settings.value_font_size }}px;
    padding: {{ section.settings.cell_padding }}px;
    text-align: center;
    align-self: center;
  }

  {%- comment -%} 手机/平板端：sticky 第一列 + 横向滚动 {%- endcomment -%}
  @media screen and (min-width:750px) and (max-width:989px) {
    .series-comparison-table-sl {
      padding: 0 20px;
    }
    .series-comparison-table__product-price{
      font-size: 20px;
    }
    .series-comparison-table__product-compare-at-price{
      font-size: 12px;
      position: relative;
      
    }
    .series-comparison-table__header{
      margin-bottom: 0px;
      padding-bottom: 20px;
    }
    .series-comparison-table__product-button{
      font-size: 14px;
      padding: 3px 12px;
    }
    .series-comparison-table__product-title-wrap{
      width: 120px;
      height:42px;
      text-align: center;
    }
    .series-comparison-table__label>p{
      font-size: 17px;
      padding: 5px;
    }
    .series-comparison-table__value{
      font-size: 16px;
    }
  }
  @media screen and (max-width: 749px) {
    .series-comparison-table-sl {
      padding: 0 {{ section.settings.mobile_outer_padding }}px;
    }
    .series-comparison-table {
      padding: {{ section.settings.table_padding_mobile }}px;
      border-radius: {{ section.settings.mobile_table_radius }}px;
    }

    /* 滚动容器 */
    .series-comparison-table-sl .series-comparison-table__scroll-wrapper {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .series-comparison-table__header {
      grid-template-columns: {{ section.settings.mobile_sticky_label_width }}px repeat(3, {{ section.settings.mobile_product_col_min }}px);
      gap: {{ section.settings.column_gap_mobile }}px;
      margin-bottom: 0px;
      padding-bottom: 0;
    }

    /* Header 第一列 sticky：透明容器，背景由内部 p 承担，避免与表格渐变冲突 */
    .series-comparison-table__header-cell--label {
      position: sticky;
      left: 0;
      z-index: 3;
      background: transparent;
      transition: background-color 0.25s ease;
    }
    /* 滚动后：纯色加深黑，遮住后面内容 */
    .series-comparison-table__header-cell--label.is-scrolled {
      background-color: #0a0a0a;
    }

    .series-comparison-table__body {
      display: block;
    }

    /* Row 改为 display:grid（display:contents 不支持 sticky） */
    .series-comparison-table__row {
      display: grid;
      grid-template-columns: {{ section.settings.mobile_sticky_label_width }}px repeat(3, {{ section.settings.mobile_product_col_min }}px);
      gap: {{ section.settings.column_gap_mobile }}px;
      margin-bottom: 0px;
    }
    .series-comparison-table__row:last-child {
      margin-bottom: 0;
    }

    /* Body 第一列 sticky：透明容器，背景由内部 p 承担（避免与卡片渐变背景冲突） */
    .series-comparison-table__label {
      position: sticky;
      left: 0;
      z-index: 2;
      padding: 0;
      background: transparent;
      transition: background-color 0.25s ease;
    }
    /* 滚动后：纯色加深黑，遮住后面内容 */
    .series-comparison-table__label.is-scrolled {
      background-color: #0a0a0a;
    }
    .series-comparison-table__label.is-scrolled > p {
      background: transparent;
    }
    .series-comparison-table__label::before {
      content: none;
    }
    .series-comparison-table__label > p {
      position: relative;
      z-index: 1;
      font-size: {{ section.settings.label_font_size_mobile }}px;
      padding: 4px 6px;
      border-radius: 4px;
      {% comment %} background: linear-gradient(0deg, #271716 0%, #1f1817 10%, #151414 80%); {% endcomment %}
    }
    .series-comparison-table__label > p > span {
      display: inline-block;
      background: linear-gradient(45deg, #f10606 20%, #ffc5c5 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .series-comparison-table__value {
      font-size: {{ section.settings.value_font_size_mobile }}px;
      padding: 0;
    }

    .series-comparison-table__product-title{
      font-size: {{ section.settings.mobile_title_size }}px;
      padding: 2px 6px;
      bottom:5px;
      left:-5px;
    }

    .series-comparison-table__product-price-wrap{
      gap: 2px;
      margin-bottom: 0px;
      flex-wrap: nowrap;
    }

    .series-comparison-table__product-price{
      font-size: {{ section.settings.mobile_price_size }}px;
    }

    .series-comparison-table__product-compare-at-price{
      font-size: {{ section.settings.mobile_compare_at_size }}px;
      position: relative;

    }

    .series-comparison-table__product-button{
      font-size: {{ section.settings.mobile_button_size }}px;
      padding: 3px 10px;
    }
    .series-comparison-table__product-title-wrap{
      width: {{ section.settings.mobile_title_bg_width }}px;
      height:22px;
      text-align: center;

    }
  }
</style>

<script>
  (function() {
    function init() {
      // 手机端：第一列背景随滚动状态切换（默认透明，滚动后纯色加深黑）
      document.querySelectorAll('.series-comparison-table__scroll-wrapper').forEach(function(wrapper) {
        const table = wrapper.closest('.series-comparison-table-sl');
        if (!table) return;
        const labels = table.querySelectorAll('.series-comparison-table__label');
        const headerLabel = table.querySelector('.series-comparison-table__header-cell--label');
        if (!labels.length && !headerLabel) return;

        function syncBg() {
          const scrolled = wrapper.scrollLeft > 5;
          labels.forEach(function(el) { el.classList.toggle('is-scrolled', scrolled); });
          if (headerLabel) headerLabel.classList.toggle('is-scrolled', scrolled);
        }
        wrapper.addEventListener('scroll', syncBg, { passive: true });
        syncBg();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<div class="series-comparison-table-sl">
  <div class="series-comparison-table">
    <div class="series-comparison-table__scroll-wrapper">
    <div class="series-comparison-table__header">
        <div class="series-comparison-table__header-cell series-comparison-table__header-cell--label"></div>
      {%- if product_1 or section.settings.product_1_image -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {%- if product_1_image -%}
              {{- product_1_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
            {%- endif -%}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            {%- if product_1 -%}
              <a href="{{ product_1.url }}" class="series-comparison-table__product-title">{{ product_1_title }}</a>
            {%- else -%}
              <span class="series-comparison-table__product-title">{{ product_1_title }}</span>
            {%- endif -%}
          </div>
          {%- if product_1 -%}
            <div class="series-comparison-table__product-price-wrap">
              <span class="series-comparison-table__product-price">{{ p1_display_price | money }}</span>
              {%- if p1_compare_price > p1_display_price -%}
                <span class="series-comparison-table__product-compare-at-price">{{ p1_compare_price | money }}</span>
              {%- endif -%}
            </div>
            <a href="{{ product_1.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if product_2 or section.settings.product_2_image -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {%- if product_2_image -%}
              {{- product_2_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
            {%- endif -%}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            {%- if product_2 -%}
              <a href="{{ product_2.url }}" class="series-comparison-table__product-title">{{ product_2_title }}</a>
            {%- else -%}
              <span class="series-comparison-table__product-title">{{ product_2_title }}</span>
            {%- endif -%}
          </div>
          {%- if product_2 -%}
            <div class="series-comparison-table__product-price-wrap">
              <span class="series-comparison-table__product-price">{{ p2_display_price | money }}</span>
              {%- if p2_compare_price > p2_display_price -%}
                <span class="series-comparison-table__product-compare-at-price">{{ p2_compare_price | money }}</span>
              {%- endif -%}
            </div>
            <a href="{{ product_2.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if product_3 or section.settings.product_3_image -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {%- if product_3_image -%}
              {{- product_3_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
            {%- endif -%}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            {%- if product_3 -%}
              <a href="{{ product_3.url }}" class="series-comparison-table__product-title">{{ product_3_title }}</a>
            {%- else -%}
              <span class="series-comparison-table__product-title">{{ product_3_title }}</span>
            {%- endif -%}
          </div>
          {%- if product_3 -%}
            <div class="series-comparison-table__product-price-wrap">
              <span class="series-comparison-table__product-price">{{ p3_display_price | money }}</span>
              {%- if p3_compare_price > p3_display_price -%}
                <span class="series-comparison-table__product-compare-at-price">{{ p3_compare_price | money }}</span>
              {%- endif -%}
            </div>
            <a href="{{ product_3.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="series-comparison-table__body">
      {%- for block in section.blocks -%}
        <div class="series-comparison-table__row">
          <div class="series-comparison-table__label"><p><span>{{ block.settings.label }}</span></p></div>
          <div class="series-comparison-table__value">{{ block.settings.value_1 }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_2 }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_3 }}</div>
        </div>
      {%- endfor -%}
    </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Series Comparison Table",
  "class": "shopify-section--series-comparison-table",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"]
  },
  "settings": [
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "table_padding_mobile",
      "label": "Table padding (mobile)",
      "min": 0,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#ff0000"
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "Column gap (mobile)",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 5
    },
    {
      "type": "range",
      "id": "mobile_sticky_label_width",
      "label": "Sticky label column width (mobile)",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "mobile_product_col_min",
      "label": "Product column min width (mobile)",
      "min": 80,
      "max": 180,
      "step": 10,
      "unit": "px",
      "default": 90
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 4,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
