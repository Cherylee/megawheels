{%- render 'section-spacing-collapsing' -%}

{%- assign product_1 = all_products[section.settings.product_1_handle] -%}
{%- assign product_2 = all_products[section.settings.product_2_handle] -%}
{%- assign product_3 = all_products[section.settings.product_3_handle] -%}

<style>
  #shopify-section-{{ section.id }} {
    padding-top: 20px;
    padding-bottom: 20px;
    background: linear-gradient(0deg, #2b0101 0%, #000000 10%);
  }

  .series-comparison-table {
    max-width: 1440px;
    margin: 0 auto;
    background: #151414;
    border-radius: 10px;
    overflow: hidden;
    padding: 0 20px;
   }

  .series-comparison-table__header {
    display: grid;
    grid-template-columns: 1fr repeat(3, 1fr);
    gap: 10px;
    margin-bottom: {{ section.settings.header_body_gap }}px;
    padding-bottom: {{ section.settings.header_body_gap }}px;
  }

  .series-comparison-table__header-cell {
    text-align: center;
  }

  .series-comparison-table__product-image {
    aspect-ratio: {{ section.settings.product_image_aspect_ratio }};
    overflow: hidden;
    margin-bottom: {{ section.settings.image_title_gap }}px;
  }

  .series-comparison-table__product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: transparent;
  }

  .series-comparison-table__product-title-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: {{ section.settings.title_price_gap }}px;
  }

  .series-comparison-table__product-title-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    background: {{ section.settings.title_background }};
    clip-path: polygon(10% 0%, 90% 5%, 100% 100%, 0% 95%);
    z-index: 0;
  }

  .series-comparison-table__product-title {
    position: relative;
    color: {{ section.settings.product_title_color }};
    font-size: {{ section.settings.product_title_font_size }}px;
    font-weight: 800;
    text-decoration: none;
    display: inline-block;
    z-index: 1;
    padding: 4px 16px;
  }

  .series-comparison-table__product-price {
    color: {{ section.settings.product_price_color }};
    font-size: {{ section.settings.product_price_font_size }}px;
    font-weight: 700;
    margin-bottom: {{ section.settings.price_button_gap }}px;
  }

  .series-comparison-table__product-button {
    display: inline-block;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    background: linear-gradient(180deg, {{ section.settings.button_background }} 0%, {{ section.settings.button_background_dark }} 100%);
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(255,0,0,0.3);
    border: none;
    cursor: pointer;
  }

  .series-comparison-table__product-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(255,0,0,0.4);
  }

  .series-comparison-table__body {
    display: grid;
    grid-template-columns: 1fr repeat(3, 1fr);
    gap: {{ section.settings.row_gap }}px;
  }

  .series-comparison-table__row {
    display: contents;
  }

  .series-comparison-table__label {
    font-size: 18px;
    font-weight: 600;
    padding: 10px;
    align-self: center;
    text-align: left;
    background: linear-gradient(45deg, red, #fff);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .series-comparison-table__value {
    color: {{ section.settings.value_color }};
    font-size: {{ section.settings.value_font_size }}px;
    padding: {{ section.settings.cell_padding }}px;
    text-align: center;
    align-self: center;
  }

  @media screen and (max-width: 900px) {
    .series-comparison-table__header {
      grid-template-columns: 1fr;
      gap: {{ section.settings.column_gap_mobile }}px;
    }

    .series-comparison-table__body {
      grid-template-columns: 1fr 1fr;
      gap: {{ section.settings.row_gap_mobile }}px;
    }

    .series-comparison-table__row {
      display: block;
      border-bottom: 1px solid {{ section.settings.border_color }};
      padding-bottom: {{ section.settings.row_gap_mobile }}px;
      margin-bottom: {{ section.settings.row_gap_mobile }}px;
    }

    .series-comparison-table__label {
      grid-column: 1;
    }

    .series-comparison-table__value:nth-child(2) {
      grid-column: 2;
    }

    .series-comparison-table__value:nth-child(3),
    .series-comparison-table__value:nth-child(4) {
      grid-column: span 2;
      text-align: left;
      padding-left: calc({{ section.settings.cell_padding }}px + 12px);
    }
  }

  @media screen and (max-width: 480px) {
    .series-comparison-table {
      padding: {{ section.settings.container_padding_mobile }}px;
    }

    .series-comparison-table__body {
      grid-template-columns: 1fr;
    }

    .series-comparison-table__value:nth-child(3),
    .series-comparison-table__value:nth-child(4) {
      grid-column: 1;
    }
  }
</style>

<div {% render 'section-properties' %}>
  <div class="series-comparison-table">
    <div class="series-comparison-table__header">
        <div class="series-comparison-table__header-cell"></div>
      {%- if product_1 -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {{- product_1.featured_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            <a href="{{ product_1.url }}" class="series-comparison-table__product-title">{{ product_1.title }}</a>
          </div>
          <div class="series-comparison-table__product-price">{{ product_1.price | money }}</div>
          <a href="{{ product_1.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
        </div>
      {%- endif -%}
      {%- if product_2 -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {{- product_2.featured_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            <a href="{{ product_2.url }}" class="series-comparison-table__product-title">{{ product_2.title }}</a>
          </div>
          <div class="series-comparison-table__product-price">{{ product_2.price | money }}</div>
          <a href="{{ product_2.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
        </div>
      {%- endif -%}
      {%- if product_3 -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {{- product_3.featured_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            <a href="{{ product_3.url }}" class="series-comparison-table__product-title">{{ product_3.title }}</a>
          </div>
          <div class="series-comparison-table__product-price">{{ product_3.price | money }}</div>
          <a href="{{ product_3.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
        </div>
      {%- endif -%}
    </div>

    <div class="series-comparison-table__body">
      {%- for block in section.blocks -%}
        <div class="series-comparison-table__row">
          <div class="series-comparison-table__label">{{ block.settings.label }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_1 }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_2 }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_3 }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

