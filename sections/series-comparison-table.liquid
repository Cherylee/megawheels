{%- render 'section-spacing-collapsing' -%}

{%- assign product_1 = all_products[section.settings.product_1_handle] -%}
{%- assign product_2 = all_products[section.settings.product_2_handle] -%}
{%- assign product_3 = all_products[section.settings.product_3_handle] -%}

{%- assign product_1_image = section.settings.product_1_image | default: product_1.featured_image -%}
{%- assign product_2_image = section.settings.product_2_image | default: product_2.featured_image -%}
{%- assign product_3_image = section.settings.product_3_image | default: product_3.featured_image -%}

{%- assign product_1_title = section.settings.product_1_title | default: product_1.title -%}
{%- assign product_2_title = section.settings.product_2_title | default: product_2.title -%}
{%- assign product_3_title = section.settings.product_3_title | default: product_3.title -%}

<style>
  #shopify-section-{{ section.id }} {
    padding-top: 20px;
    padding-bottom: 20px;
    background: linear-gradient(0deg, #5a0909 -1%, #200505 5%, #000000 80%);
  }
  .series-comparison-table-sl{
  }

  .series-comparison-table {
    max-width: 1240px;
    margin: 0 auto;
    {% comment %} background: rgba(21,20,20,0.5); {% endcomment %}
    border-radius: 30px;
    overflow: hidden;
    padding: 20px 20px;
    box-shadow: 0 90px 800px 10px rgba(255, 255, 255, 0.1);
    background: linear-gradient(0deg, #271716 0%, #1f1817 10%, #151414 80%);
   }

  .series-comparison-table__header {
    display: grid;
    grid-template-columns: 1fr repeat(3, 1fr);
    gap: 10px;
    margin-bottom: {{ section.settings.header_body_gap }}px;
    padding-bottom: {{ section.settings.header_body_gap }}px;
  }

  .series-comparison-table__header-cell {
    text-align: center;
  }

  .series-comparison-table__product-image {
    aspect-ratio: {{ section.settings.product_image_aspect_ratio }};
    overflow: hidden;
    margin-bottom: {{ section.settings.image_title_gap }}px;
  }

  .series-comparison-table__product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: transparent;
  }

  .series-comparison-table__product-title-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: {{ section.settings.title_price_gap }}px;
  }

  .series-comparison-table__product-title-bg {
    position: absolute;
    width: 100%;
    height: 100%;
    background: url('https://cdn.shopify.com/s/files/1/0593/5883/8992/files/huaban-5539078913.png?v=1783930065') no-repeat center center;
    z-index: 0;
    background-size: 100% 100%;
  }

  .series-comparison-table__product-title {
    position: relative;
    color: {{ section.settings.product_title_color }};
    font-size: {{ section.settings.product_title_font_size }}px;
    font-weight: 800;
    text-decoration: none;
    display: inline-block;
    z-index: 1;
    padding: 4px 16px;
    max-width: 300px;
  }

  .series-comparison-table__product-price {
    font-weight: 800;
    {% comment %} background: linear-gradient(45deg, #f10606, #fff); {% endcomment %}
    background: linear-gradient(0deg, #f10606 40%, #ffffff 100%)!important;
    -webkit-background-clip: text!important;
    background-clip: text!important;
    color: transparent;
    margin-bottom: {{ section.settings.price_button_gap }}px;
    font-size:32px;
    display: block;
    width: fit-content;
    margin:0 auto;
    -webkit-text-stroke: 0.3px #000000;
  }

  .series-comparison-table__product-button {
    display: inline-block;
    padding: 5px 28px;
    background: linear-gradient(180deg, {{ section.settings.button_background }} 0%, {{ section.settings.button_background_dark }} 100%);
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .series-comparison-table__product-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(255,0,0,0.4);
  }

  .series-comparison-table__body {
    display: grid;
    grid-template-columns: 1fr repeat(3, 1fr);
    gap: {{ section.settings.row_gap }}px;
  }

  .series-comparison-table__row {
    display: contents;
  }

  .series-comparison-table__label {
    font-size: 20px;
    font-weight: 800;
    padding: 10px;
    align-self: center;
    text-align: left;
    background: linear-gradient(45deg, #f10606 20%, #ffc5c5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .series-comparison-table__value {
    color: #ffffff;
    font-size: 20px;
    padding: {{ section.settings.cell_padding }}px;
    text-align: center;
    align-self: center;
  }

  @media screen and (max-width: 900px) {
    .series-comparison-table__header {
      grid-template-columns: 1fr;
      gap: {{ section.settings.column_gap_mobile }}px;
    }

    .series-comparison-table__body {
      grid-template-columns: 1fr 1fr;
      gap: {{ section.settings.row_gap_mobile }}px;
    }

    .series-comparison-table__row {
      display: block;
      border-bottom: 1px solid {{ section.settings.border_color }};
      padding-bottom: {{ section.settings.row_gap_mobile }}px;
      margin-bottom: {{ section.settings.row_gap_mobile }}px;
    }

    .series-comparison-table__label {
      grid-column: 1;
    }

    .series-comparison-table__value:nth-child(2) {
      grid-column: 2;
    }

    .series-comparison-table__value:nth-child(3),
    .series-comparison-table__value:nth-child(4) {
      grid-column: span 2;
      text-align: left;
      padding-left: calc({{ section.settings.cell_padding }}px + 12px);
    }
  }

  @media screen and (max-width: 480px) {
    .series-comparison-table {
      padding: {{ section.settings.container_padding_mobile }}px;
    }

    .series-comparison-table__body {
      grid-template-columns: 1fr;
    }

    .series-comparison-table__value:nth-child(3),
    .series-comparison-table__value:nth-child(4) {
      grid-column: 1;
    }
  }
</style>

<div class="series-comparison-table-sl">
  <div class="series-comparison-table">
    <div class="series-comparison-table__header">
        <div class="series-comparison-table__header-cell"></div>
      {%- if product_1 or section.settings.product_1_image -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {%- if product_1_image -%}
              {{- product_1_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
            {%- endif -%}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            {%- if product_1 -%}
              <a href="{{ product_1.url }}" class="series-comparison-table__product-title">{{ product_1_title }}</a>
            {%- else -%}
              <span class="series-comparison-table__product-title">{{ product_1_title }}</span>
            {%- endif -%}
          </div>
          {%- if product_1 -%}
            <div class="series-comparison-table__product-price">{{ product_1.price | money }}</div>
            <a href="{{ product_1.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if product_2 or section.settings.product_2_image -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {%- if product_2_image -%}
              {{- product_2_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
            {%- endif -%}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            {%- if product_2 -%}
              <a href="{{ product_2.url }}" class="series-comparison-table__product-title">{{ product_2_title }}</a>
            {%- else -%}
              <span class="series-comparison-table__product-title">{{ product_2_title }}</span>
            {%- endif -%}
          </div>
          {%- if product_2 -%}
            <div class="series-comparison-table__product-price">{{ product_2.price | money }}</div>
            <a href="{{ product_2.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if product_3 or section.settings.product_3_image -%}
        <div class="series-comparison-table__header-cell">
          <div class="series-comparison-table__product-image">
            {%- if product_3_image -%}
              {{- product_3_image | image_url: width: 400 | image_tag: sizes: '(max-width: 768px) 100%, 300px' -}}
            {%- endif -%}
          </div>
          <div class="series-comparison-table__product-title-wrap">
            <div class="series-comparison-table__product-title-bg"></div>
            {%- if product_3 -%}
              <a href="{{ product_3.url }}" class="series-comparison-table__product-title">{{ product_3_title }}</a>
            {%- else -%}
              <span class="series-comparison-table__product-title">{{ product_3_title }}</span>
            {%- endif -%}
          </div>
          {%- if product_3 -%}
            <div class="series-comparison-table__product-price">{{ product_3.price | money }}</div>
            <a href="{{ product_3.url }}" class="series-comparison-table__product-button">{{ section.settings.button_text }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="series-comparison-table__body">
      {%- for block in section.blocks -%}
        <div class="series-comparison-table__row">
          <div class="series-comparison-table__label">{{ block.settings.label }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_1 }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_2 }}</div>
          <div class="series-comparison-table__value">{{ block.settings.value_3 }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

