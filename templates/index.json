    "testimonial_carousel_Rx4iyb": {
      "type": "testimonial-carousel",
      "blocks": {
        "review_4cmQ8U": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/MEGAWHEELS-D2-LITE-electric-dirt-bike-review-600x600-01.jpg",
            "review_title": "Son loves it – great power and battery life",
            "review_stars": "5",
            "review_content": "Bought this for my 14‑year‑old son who’s been begging for an e-moto. He absolutely loves it. Highly recommend for teens and adults who want real off-road performance.",
            "review_author": "Daniel A. Giroux"
          }
        },
        "review_AgmHkV": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/MEGAWHEELS-D2-electric-dirt-bike-review-600x600-01.jpg",
            "review_title": "Exceeded all my expectations",
            "review_stars": "5",
            "review_content": "This was my first electric dirt bike and I couldn't be happier. I was worried about the learning curve, but the throttle response is smooth and predictable.",
            "review_author": "Thomas H. McNeil"
          }
        },
        "review_bTnz9V": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/MEGAWHEELS-D2-Pro-electric-dirt-bike-review-600x600-02.jpg",
            "review_title": "Absolute Beast of a Machine",
            "review_stars": "5",
            "review_content": "The D2 Pro dirt bike is a monster! Its 6000W peak motor rockets to 50mph, and the 226N.m torque devours 35° hills. Durable, grippy, and smooth over bumps.",
            "review_author": "Joby Chain"
          }
        },
        "review_ekaBcx": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/MEGAWHEELS-D2-electric-dirt-bike-review-600x600-03.jpg",
            "review_title": "My son loves it! Great Dirt bike for the price",
            "review_stars": "5",
            "review_content": "Bought this electric dirt bike for teens (my son is 17) and he is obsessed. It looks super cool, and the speed is thrilling—he hits 38+ mph easily. It is a great choice as a present.",
            "review_author": "Eva"
          }
        },
        "review_BxgYXm": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/MEGAWHEELS-D2-electric-dirt-bike-500x500-01.jpg",
            "review_title": "Torquey little beast for a big rider",
            "review_stars": "5",
            "review_content": "I'm 6'2\" and weigh 209 lbs, so I wasn't sure what to expect from an electric dirt bike. But the 3550W peak motor and 204 Nm of torque do move my weight surprisingly well.",
            "review_author": "Dan Furtea"
          }
        },
        "review_TJMTqR": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/MEGAWHEELS-D2-electric-dirt-bike-review-600x600-02.jpg",
            "review_title": "Beast of a bike for the price",
            "review_stars": "5",
            "review_content": "I've been riding dirt bikes for years and decided to try an electric model. This thing is a beast! If you're looking for an e-dirt bike that actually performs, this is it.",
            "review_author": "John S. Byrd"
          }
        }
      },
